{
  "name": "momentum-picker",
  "version": "0.2.0",
  "description": "A production-ready iOS-style wheel DateTime picker for the web. Zero dependencies, Vanilla TypeScript.",
  "keywords": [
    "ios",
    "datetime",
    "picker",
    "wheel",
    "scroll",
    "momentum",
    "date",
    "time",
    "mobile",
    "typescript"
  ],
  "author": "Rabin Phaiju",
  "license": "MIT",
  "homepage": "https://github.com/RabinPhaiju/momentum-picker/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/RabinPhaiju/momentum-picker.git"
  },
  "bugs": {
    "url": "https://github.com/RabinPhaiju/momentum-picker/issues"
  },
  "main": "./dist/momentum-picker.umd.js",
  "module": "./dist/momentum-picker.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/momentum-picker.es.js",
      "require": "./dist/momentum-picker.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite example --host",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist/types",
    "build:demo": "vite build example --outDir ../docs --base /momentum-picker/ --emptyOutDir",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1",
    "vue": "^3.5.29"
  }
}
